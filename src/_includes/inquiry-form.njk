          <div class="inquiry__form">
            <!-- Progress indicator -->
            <div class="form-progress">
              <div class="form-progress__track">
                <div class="form-progress__fill" id="form-progress-fill" style="width: 25%"></div>
              </div>
              <div class="form-progress__label" id="form-progress-label">Step 1 of 4</div>
            </div>

            <form action="/" method="post" name="{{ formName }}" id="inquiry-form" data-netlify="true" data-netlify-honeypot="bot-field">
              <input type="hidden" name="form-name" value="{{ formName }}">
              <input type="hidden" name="source_page" value="{{ sourcePage }}">
              <p hidden><label>Don't fill this out: <input name="bot-field"></label></p>

              <!-- Step 1: Timeline / Intent -->
              <div class="form-step is-active" data-step="1">
                <div class="form-step__heading">When are you ideally looking to plan your trip?</div>
                <div class="intent-options">
                  <label class="intent-option">
                    <input type="radio" name="trip_timeline" value="this-season">
                    <span class="intent-option__label">This season</span>
                  </label>
                  <label class="intent-option">
                    <input type="radio" name="trip_timeline" value="next-season">
                    <span class="intent-option__label">Next season</span>
                  </label>
                  <label class="intent-option">
                    <input type="radio" name="trip_timeline" value="just-exploring">
                    <span class="intent-option__label">Just exploring for now</span>
                  </label>
                </div>
                <div class="form-step-nav">
                  <button type="button" class="btn-step-next" data-next="2">Continue →</button>
                </div>
              </div>

              <!-- Step 2: When & Who -->
              <div class="form-step" data-step="2">
                <div class="form-step__heading">When would you like to go?</div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="dates">Preferred Dates</label>
                    <select id="dates" name="dates">
                      <option value="">Select a window</option>
                      <option value="june-1-7">June 1–7</option>
                      <option value="june-14" disabled>June 14–21 — Booked</option>
                      <option value="june-22-28">June 22–28</option>
                      <option value="july-1-7">July 1–7</option>
                      <option value="july-14" disabled>July 14–24 — Booked</option>
                      <option value="july-25-31">July 25–31</option>
                      <option value="august-1-7">August 1–7</option>
                      <option value="aug-10" disabled>August 10–15 — Booked</option>
                      <option value="august-16-22">August 16–22</option>
                      <option value="august-23-29">August 23–29</option>
                      <option value="sept-5" disabled>September 5–12 — Booked</option>
                      <option value="september-13-19">September 13–19</option>
                      <option value="september-20-26">September 20–26</option>
                      <option value="flexible">Flexible / Help me choose dates</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label for="party-size">Party Size</label>
                    <select id="party-size" name="party_size">
                      <option value="">Select</option>
                      <option value="2">2 guests</option>
                      <option value="3">3 guests</option>
                      <option value="4">4 guests</option>
                      <option value="5">5 guests</option>
                      <option value="6">6 guests</option>
                    </select>
                  </div>
                </div>
                <div class="form-group">
                  <label for="email">Email Address <span class="form-label-note">(so we can get back to you)</span></label>
                  <input type="email" id="email" name="email" placeholder="jane@example.com" required>
                </div>
                <div class="form-step-nav form-step-nav--split">
                  <button type="button" class="btn-step-back" data-prev="1">← Back</button>
                  <button type="button" class="btn-step-next" data-next="3">Continue →</button>
                </div>
              </div>

              <!-- Step 3: About You -->
              <div class="form-step" data-step="3">
                <div class="form-step__heading">A little more about yourself.</div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="first-name">First Name</label>
                    <input type="text" id="first-name" name="first_name" placeholder="Jane" required>
                  </div>
                  <div class="form-group">
                    <label for="last-name">Last Name</label>
                    <input type="text" id="last-name" name="last_name" placeholder="Smith" required>
                  </div>
                </div>
                <div class="form-group">
                  <label for="phone">Phone</label>
                  <input type="tel" id="phone" name="phone" placeholder="+1 (555) 000-0000" required>
                </div>
                <div class="form-step-nav form-step-nav--split">
                  <button type="button" class="btn-step-back" data-prev="2">← Back</button>
                  <button type="button" class="btn-step-next" data-next="4">Continue →</button>
                </div>
              </div>

              <!-- Step 4: Final -->
              <div class="form-step" data-step="4">
                <div class="form-step__heading">Almost there.</div>
                <div class="form-group">
                  <label for="message">Anything we should know? (Optional)</label>
                  <textarea id="message" name="message" placeholder="Dietary needs, special occasions, specific fishing interests..."></textarea>
                </div>
                <div class="form-step-nav form-step-nav--back-only">
                  <button type="button" class="btn-step-back" data-prev="3">← Back</button>
                </div>
                <button type="submit" class="form-submit">Request Availability</button>
                <p class="form-reassurance">We respond within 24 hours. No commitment required.</p>
              </div>

            </form>

            <!-- Confirmation state (shown after submit) -->
            <div class="inquiry__confirm" id="inquiry-confirm">
              <div class="inquiry__confirm-icon">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="11" stroke="#C9A84C" stroke-width="1.5"/>
                  <path d="M7 12.5l3.5 3.5 6.5-7" stroke="#C9A84C" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3 class="inquiry__confirm-headline">We've received your inquiry.</h3>
              <p class="inquiry__confirm-body">We'll be back within 24 hours with availability details and answers to any questions. Check your inbox, including your spam folder.</p>
              <div class="inquiry__confirm-contact">
                <a href="mailto:{{ site.email }}">{{ site.email }}</a>
                <span>&nbsp;·&nbsp;</span>
                <a href="tel:{{ site.phone }}">{{ site.phoneDisplay }}</a>
              </div>
              <div class="inquiry__confirm-links">
                <a href="itinerary.html">Review the Route →</a>
                <a href="crew.html">Meet the Crew →</a>
              </div>
            </div>
          </div>
