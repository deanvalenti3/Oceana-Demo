---
layout: layout.njk
title: Check Availability — Motor Yacht Oceana Alaska Charter
description: Request availability for a private Alaska yacht charter aboard M/Y Oceana. We respond within 24 hours. No commitment required.
navActive: contact
permalink: contact.html
---

  <!-- PAGE HERO -->
  <section class="page-hero page-hero--short" style="--bg: url('assets/images/oceana_imgs/hero.webp');">
    <div class="container">
      <div class="page-hero__content">
        <div class="page-hero__eyebrow">2026 Season</div>
        <h1 class="page-hero__headline">Reserve Your Expedition</h1>
        <p class="page-hero__sub">A handful of charters per season. Tell us your dates and we'll be back to you within 24 hours.</p>
      </div>
    </div>
  </section>

  <!-- CONTACT FORM -->
  <section class="inquiry contact-page" id="inquiry">
    <div class="container">
      <div class="inquiry__inner">

        <div class="inquiry__left">
          <div class="section-label">Start Here</div>
          <h2>Let's Talk About Your Trip</h2>
          <p>
            Fill out the short form and we'll respond within 24 hours with date options, full itinerary details, and answers to any questions. No commitment required to inquire.
          </p>

          <div class="inquiry__contact">
            <div class="inquiry__contact-item">
              <div class="inquiry__contact-icon">
                <svg viewBox="0 0 24 24" stroke-width="1.8" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <a href="mailto:{{ site.email }}">{{ site.email }}</a>
            </div>
            <div class="inquiry__contact-item">
              <div class="inquiry__contact-icon">
                <svg viewBox="0 0 24 24" stroke-width="1.8" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <a href="tel:{{ site.phone }}">{{ site.phoneDisplay }}</a>
            </div>
            <div class="inquiry__contact-item">
              <div class="inquiry__contact-icon">
                <svg viewBox="0 0 24 24" stroke-width="1.8" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              </div>
              <span>WhatsApp available on request</span>
            </div>
          </div>

        </div>

        {% set formName = "inquiry-contact" %}
        {% set sourcePage = "contact" %}
        {% include "inquiry-form.njk" %}

      </div>
    </div>
  </section>
